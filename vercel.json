{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "builds": [
    {
      "src": "index.py",
      "use": "@vercel/python",
      "config": {
        "includeFiles": [
          "api/**",
          "greenhouse/**",
          "production/**",
          "ui/**",
          "ui/public/**",
          "ui/admin/**",
          "data/catalog.json"
        ]
      }
    }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "index.py" }
  ]
}
