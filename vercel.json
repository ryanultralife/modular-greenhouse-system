{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "builds": [
    {
      "src": "index.py",
      "use": "@vercel/python",
      "config": {
        "includeFiles": [
          "api/**",
          "greenhouse/**",
          "production/**",
          "data/catalog.json"
        ]
      }
    },
    { "src": "ui/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "index.py" },
    { "src": "/health", "dest": "index.py" },
    { "src": "/admin/?", "dest": "/ui/admin/index.html" },
    { "src": "/admin/(.+)", "dest": "/ui/admin/$1" },
    { "src": "/", "dest": "/ui/public/index.html" },
    { "src": "/(.+)", "dest": "/ui/public/$1" }
  ],
  "crons": [
    { "path": "/api/cron/automations", "schedule": "0 * * * *" }
  ]
}
